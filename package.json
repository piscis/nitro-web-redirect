{
  "name": "nitro-web-redirect",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": "22.15.0"
  },
  "scripts": {
    "clean": "rimraf .output .nitro node_modules",
    "start": "node .output/server/index.mjs",
    "build": "nitro build",
    "dev": "nitro dev",
    "preview": "nitro preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest --run",
    "release:patch": "release-it -i patch --only-version",
    "release:minor": "release-it -i minor --only-version",
    "release:major": "release-it -i major --only-version"
  },
  "dependencies": {
    "consola": "^3.4.2"
  },
  "imports": {
    "#*": "./*"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "nitro": "latest",
    "nitro-test-utils": "^1.0.0",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "ufo": "^1.6.3",
    "vitest": "^4.1.0"
  }
}
